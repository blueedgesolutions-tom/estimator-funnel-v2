# ─────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────

# Vercel Edge Config connection string (from Vercel dashboard)
VERCEL_EDGE_CONFIG=

# ─────────────────────────────────────────────────────────
# ANALYTICS
# ─────────────────────────────────────────────────────────

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─────────────────────────────────────────────────────────
# IMAGE STORAGE
# ─────────────────────────────────────────────────────────

BLOB_READ_WRITE_TOKEN=

# ─────────────────────────────────────────────────────────
# ADDRESS AUTOCOMPLETE & GEOCODING
# ─────────────────────────────────────────────────────────

GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────
# EMAIL
# ─────────────────────────────────────────────────────────

RESEND_API_KEY=

# ─────────────────────────────────────────────────────────
# JOB STATE (async processing)
# ─────────────────────────────────────────────────────────

REDIS_URL=

# ─────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT
# ─────────────────────────────────────────────────────────

# Slug to resolve when no subdomain / ?tenant= param is present
DEV_TENANT_SLUG=aquadreams

# Paste a full RawTenantConfig JSON here to bypass Edge Config lookup entirely.
# Useful for offline development or testing new config schemas.
# LOCAL_TENANT_CONFIG={"version":"1.0","config":{...}}

# Vercel deployment protection bypass token (for webhook callbacks in preview)
# VERCEL_BYPASS_TOKEN=
